# ─────────────────────────────────────────────────────────────────────
# nori-wesite (Marketing Site) — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# Site Configuration
SITE_URL=https://nori.dev
SITE_NAME=Nori
SITE_DESCRIPTION=The modern terminal for developers

# Analytics (optional)
# VITE_ANALYTICS_ID=your-analytics-id

# Backend API URL (for download counters, etc.)
# VITE_API_URL=https://api.nori.dev
